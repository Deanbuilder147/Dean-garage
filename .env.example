# 机甲战棋 - 环境变量配置示例
# 复制此文件为 .env 并填入实际值
# 命令：cp .env.example .env

# ===========================================
# 数据库配置 (PostgreSQL)
# ===========================================
POSTGRES_DB=mecha_battle
POSTGRES_USER=mecha_user
POSTGRES_PASSWORD=<在此粘贴 openssl rand -base64 32 的输出>

# ===========================================
# JWT 认证配置
# ===========================================
JWT_SECRET=<在此粘贴 openssl rand -base64 64 的输出>

# ===========================================
# 运行环境
# ===========================================
NODE_ENV=production
# NODE_ENV=development  # 开发环境

# ===========================================
# 服务端口配置
# ===========================================
AUTH_SERVICE_PORT=3001
HANGAR_SERVICE_PORT=3002
MAP_SERVICE_PORT=3003
COMBAT_SERVICE_PORT=3004
COMM_SERVICE_PORT=3005
FRONTEND_PORT=8081

# ===========================================
# 数据库连接 URL (Docker 内部使用)
# 格式：postgresql://用户：密码@主机：端口/数据库名
# ===========================================
DATABASE_URL=postgresql://${POSTGRES_USER}:${POSTGRES_PASSWORD}@postgres:5432/${POSTGRES_DB}

# ===========================================
# 服务间通信 URL (Docker 网络)
# ===========================================
AUTH_SERVICE_URL=http://auth-service:3001
HANGAR_SERVICE_URL=http://hangar-service:3002
MAP_SERVICE_URL=http://map-service:3003
COMBAT_SERVICE_URL=http://combat-service:3004
COMM_SERVICE_URL=http://comm-service:3005

# ===========================================
# Combat Service 数据目录
# ===========================================
DB_PATH=/app/data/combat.db

# ===========================================
# 云服务器 IP (如需外部访问请修改)
# ===========================================
SERVER_IP=0.0.0.0

# ===========================================
# CORS 配置 - 允许的域名列表（逗号分隔）
# 生产环境请修改为你的实际域名
# ===========================================
ALLOWED_ORIGINS=http://localhost:8081,http://localhost:8080,https://yourdomain.com
