# 数据库配置
DATABASE_URL=postgresql://user:password@localhost:5432/mecha_battle

# JWT 认证密钥
JWT_SECRET=your-super-secret-key-change-this-in-production

# 环境模式
NODE_ENV=development

# 各服务端口
AUTH_SERVICE_PORT=3001
HANGAR_SERVICE_PORT=3002
MAP_SERVICE_PORT=3003
COMBAT_SERVICE_PORT=3004
COMM_SERVICE_PORT=3005
FRONTEND_PORT=8081
